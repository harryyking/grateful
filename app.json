{
  "expo": {
    "name": "Grateful",
    "slug": "grateful",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "grateful",
    "ios": {
      "icon": "./assets/images/icon.png",
      "bundleIdentifier": "com.harryyking.grateful",
      "supportsTablet": false,
      "requireFullScreen": true,
      "userInterfaceStyle": "automatic",
      "infoPlist": {
        "CFBundleDisplayName": "Grateful",
        "ITSAppUsesNonExemptEncryption": false
      },
      "entitlements": {
        "com.apple.security.application-groups": [
          "group.com.harryyking.grateful"
        ]
      }
    },
    "web": {
      "output": "server",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "voltra",
        {
          "groupIdentifier": "group.com.harryyking.grateful",
          "enablePushNotifications": true
        }
      ],
      [
        "expo-router"
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#2b2724",
          "image": "./assets/images/splash.png",
          "resizeMode": "contain",
          "imageWidth": 200
        }
      ],
      "expo-sharing",
      "expo-secure-store",
      "expo-web-browser",
      "expo-image",
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "16.2"     
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "eb2f4e8b-5eb1-4811-b530-7f8e1b5c7890"
      }
    }
  }
}
